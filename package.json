{
  "name": "mcq-anything",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "TypeScript API backend and library for generating multiple-choice questions from a topic.",
  "scripts": {
    "test": "tsx scripts/run-tests.ts",
    "dev": "tsx src/server.ts",
    "start": "node dist/src/server.js",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3"
  }
}